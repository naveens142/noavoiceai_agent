# Pipecat Voice Agent - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED - API Keys (Must be configured before running)
# ═════════════════════════════════════════════════════════════════════════════

# Daily.co API Key - Get from https://dashboard.daily.co/developers
DAILY_API_KEY=your-daily-api-key-here

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Deepgram API Key - Get from https://console.deepgram.com/keys
DEEPGRAM_API_KEY=your-deepgram-key-here


# ═════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Server host and port
HOST=0.0.0.0
PORT=7860

# Maximum concurrent voice sessions
MAX_CONCURRENT_BOTS=20

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=/tmp/pipecat.log


# ═════════════════════════════════════════════════════════════════════════════
# AGENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

AGENT_NAME=Pipecat Voice Bot
ENVIRONMENT=development
DEBUG=false

# OpenAI model settings
OPENAI_MODEL=gpt-4o-mini
MAX_TOKENS=2048
TEMPERATURE=0.7

# TTS voice selection
TTS_VOICE=nova

# Audio settings
SAMPLE_RATE=16000


# ═════════════════════════════════════════════════════════════════════════════
# API CONFIGURATION (Optional - Update if using a backend service)
# ═════════════════════════════════════════════════════════════════════════════

API_BASE_URL=http://localhost:8000/api/v1
API_TIMEOUT=30
VERIFY_SSL=true

# Backend API authentication (if required)
AGENT_API_TOKEN=your-secret-token
AGENT_EMAIL=agent@example.com
AGENT_PASSWORD=your-password

# Or use a service token:
AGENT_API_TOKEN=your-service-token


# ═════════════════════════════════════════════════════════════════════════════
# NOTES FOR DEPLOYMENT
# ═════════════════════════════════════════════════════════════════════════════

# Local Development:
#   Copy this file to .env and fill in values
#   Run: python bot_runner.py

# Render.com Deployment:
#   1. Create new Web Service on Render
#   2. Connect your GitHub repository
#   3. Set these environment variables in Render dashboard:
#      - DAILY_API_KEY
#      - OPENAI_API_KEY
#      - DEEPGRAM_API_KEY
#      - AGENT_NAME
#      - API_BASE_URL
#   4. Render auto-deploys on git push

# Cost Tracking:
#   - Daily.co: Free tier = 10,000 participant-minutes/month
#   - Render.com: Free tier = 750 hours/month (always running = ~30 hours/day)
#   - OpenAI: Pay as you use (GPT-4o-mini is cheapest)
#   - Deepgram: Pay as you use ($0.0043/min)

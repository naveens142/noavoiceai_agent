# Pipecat Voice Agent - Environment Configuration
# SmallWebRTC Transport (peer-to-peer, no external SaaS required)
# Copy this file to .env and fill in your actual API keys

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED - API Keys (Must be configured before running)
# ═════════════════════════════════════════════════════════════════════════════

# OpenAI API Key - Get from https://platform.openai.com/api-keys
# Required for LLM (conversation) and Text-to-Speech (voice generation)
OPENAI_API_KEY=sk-your-openai-key-here

# Deepgram API Key - Get from https://console.deepgram.com/keys
# Required for Speech-to-Text (transcription of user speech)
DEEPGRAM_API_KEY=your-deepgram-key-here

# Backend API base URL for agent configuration and booking tools
# Example: http://localhost:8000 (local) or https://api.example.com (production)
API_BASE_URL=http://localhost:8000

# Backend API authentication
API_USERNAME=your-api-username
API_PASSWORD=your-api-password


# ═════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Server host - 0.0.0.0 for production (accessible from anywhere)
HOST=0.0.0.0

# Server port - where the agent listens for WebRTC connections
PORT=7860

# Maximum concurrent voice sessions allowed
MAX_CONCURRENT_BOTS=20


# ═════════════════════════════════════════════════════════════════════════════
# LOGGING & DEPLOYMENT
# ═════════════════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path - for persistent logging (optional)
LOG_FILE=/tmp/pipecat.log


# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL - TURN Server (only if you experience WebRTC connection timeouts)
# ═════════════════════════════════════════════════════════════════════════════

# METERED_TURN_URL=your-turn-server-url.metered.live
# METERED_TURN_USERNAME=your-turn-username
# METERED_TURN_CREDENTIAL=your-turn-credential
#
# Only needed if connections fail on restrictive networks (firewalls, proxies).
# Get free TURN server credentials at https://metered.ca


# ═════════════════════════════════════════════════════════════════════════════
# LLM & VOICE CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# OpenAI model selection
# Options: gpt-4, gpt-4-turbo, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Text-to-Speech voice
# Options: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=nova




# ═════════════════════════════════════════════════════════════════════════════
# QUICK START
# ═════════════════════════════════════════════════════════════════════════════

# LOCAL DEVELOPMENT:
#   1. cp .env.example .env
#   2. Fill in OPENAI_API_KEY, DEEPGRAM_API_KEY, API_BASE_URL, API_USERNAME, API_PASSWORD
#   3. python bot_runner.py
#   4. Open http://localhost:7860 in browser
#
# RENDER.COM DEPLOYMENT:
#   1. Create Web Service, connect GitHub
#   2. Set Environment → add all variables from this file
#   3. (IMPORTANT) For production: Add METERED_TURN_* variables for NAT traversal
#   4. Render auto-deploys on push
#
# PRICING:
#   - OpenAI: ~$0.005/1K input tokens (gpt-4o-mini)
#   - Deepgram: ~$0.0043/min (nova-2 STT)
#   - Render: Free tier = 750 hours/month

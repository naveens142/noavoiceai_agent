# Pipecat Voice Agent - Environment Configuration
# Copy this file to .env and fill in your actual API keys
# For Render.com deployment, add these variables in the Environment section

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED - API Keys (Must be configured before running)
# ═════════════════════════════════════════════════════════════════════════════

# Daily.co API Key - Get from https://dashboard.daily.co/developers
# Required for WebRTC signaling and room management
DAILY_API_KEY=your-daily-api-key-here

# OpenAI API Key - Get from https://platform.openai.com/api-keys
# Required for LLM and Text-to-Speech
OPENAI_API_KEY=sk-your-openai-key-here

# Deepgram API Key - Get from https://console.deepgram.com/keys
# Required for Speech-to-Text
DEEPGRAM_API_KEY=your-deepgram-key-here


# ═════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Server host - 0.0.0.0 for production (accessible from anywhere)
HOST=0.0.0.0

# Server port
PORT=7860

# Environment (development, staging, production)
ENVIRONMENT=development

# Enable debug mode (set to false for production)
DEBUG=false

# Maximum concurrent voice sessions allowed
MAX_CONCURRENT_BOTS=20


# ═════════════════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (for persistent logging)
LOG_FILE=/tmp/pipecat.log


# ═════════════════════════════════════════════════════════════════════════════
# AGENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Agent display name
AGENT_NAME=Pipecat Voice Agent

# Agent unique identifier
AGENT_ID=agent-001

# OpenAI model selection
# Options: gpt-4, gpt-4-turbo, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens for LLM responses
MAX_TOKENS=2048

# Temperature for LLM responses (0.0-1.0, higher = more creative)
TEMPERATURE=0.7

# Text-to-Speech voice
# Options: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=nova

# Audio sample rate in Hz
SAMPLE_RATE=16000


# ═════════════════════════════════════════════════════════════════════════════
# BACKEND API CONFIGURATION (if using a backend service)
# ═════════════════════════════════════════════════════════════════════════════

# Backend API base URL
API_BASE_URL=http://localhost:8000/api/v1

# API request timeout in seconds
API_TIMEOUT=30

# Verify SSL certificates (set to false only for testing)
VERIFY_SSL=true

# API authentication token
AGENT_API_TOKEN=your-secret-token

# Backend login credentials (if using JWT auth)
AGENT_EMAIL=agent@example.com
AGENT_PASSWORD=your-backend-password


# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL INTEGRATIONS
# ═════════════════════════════════════════════════════════════════════════════

# Twilio Configuration (Optional - for phone number integration)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Database Configuration (Optional - for persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/pipecat_db

# Pipecat Platform Configuration (Optional)
PIPECAT_API_KEY=your-pipecat-api-key
PIPECAT_SERVER_URL=https://api.pipecat.ai

# Sentry Error Tracking (Optional - for production monitoring)
SENTRY_DSN=https://example@sentry.io/123456


# ═════════════════════════════════════════════════════════════════════════════
# TIMEOUT & RETRY CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Maximum call duration in seconds (3600 = 1 hour)
CALL_TIMEOUT=3600

# Maximum number of retries for failed API calls
MAX_RETRIES=3

# Delay between retries in seconds
RETRY_DELAY=2


# ═════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT INSTRUCTIONS
# ═════════════════════════════════════════════════════════════════════════════

# LOCAL DEVELOPMENT:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your API keys in .env
#   3. Run: python bot_runner.py
#
# RENDER.COM DEPLOYMENT:
#   1. Create a new Web Service on Render Dashboard
#   2. Connect your GitHub repository
#   3. In Environment section, add these variables:
#      REQUIRED:
#      - DAILY_API_KEY
#      - OPENAI_API_KEY
#      - DEEPGRAM_API_KEY
#      OPTIONAL:
#      - AGENT_NAME
#      - ENVIRONMENT=production
#      - DEBUG=false
#      - LOG_LEVEL=WARNING
#      - OPENAI_MODEL
#      - API_BASE_URL
#   4. Set Build Command: pip install -r requirements.txt
#   5. Set Start Command: python bot_runner.py
#   6. Render auto-deploys on git push
#
# COSTS & LIMITS:
#   - Daily.co: Free tier = 10,000 participant-minutes/month
#   - Render.com: Free tier = 750 hours/month
#   - OpenAI: Pay-as-you-go (GPT-4o-mini ~$0.005/1K input tokens)
#   - Deepgram: Pay-as-you-go (~$0.0043/min for nova-2)
